# Provide at least one provider key. `--provider auto` picks the first available,
# in this order: anthropic → openai → gemini.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=          # (Gemini)

# Optional defaults (overridden by CLI flags)
HOTEL_AGENT_MODE=human   # human | auto
HOTEL_AGENT_PROVIDER=auto
